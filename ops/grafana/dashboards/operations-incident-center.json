{
  "id": null,
  "uid": "ops-incident-center",
  "title": "Operations Incident Center",
  "tags": [
    "operations",
    "incident",
    "loki",
    "tempo",
    "prometheus"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "custom",
        "label": "Service",
        "query": "app",
        "current": {
          "selected": true,
          "text": "app",
          "value": "app"
        },
        "options": [
          {
            "selected": true,
            "text": "app",
            "value": "app"
          }
        ]
      },
      {
        "name": "trace",
        "type": "textbox",
        "label": "Trace ID",
        "query": "",
        "current": {
          "selected": false,
          "text": "",
          "value": ""
        }
      },
      {
        "name": "corr",
        "type": "textbox",
        "label": "Correlation ID",
        "query": "",
        "current": {
          "selected": false,
          "text": "",
          "value": ""
        }
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Error Log Rate (5m)",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({compose_service=\"$service\"} | json | level=\"ERROR\" [5m]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Warn Log Rate (5m)",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 0
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({compose_service=\"$service\"} | json | level=\"WARN\" [5m]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "WS Send Failures (5m)",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(business_updates_failed_total[5m]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Tick->Screen P95 (ms)",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(business_tick_to_screen_latency_ms_bucket[5m])) by (le))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 300
              },
              {
                "color": "red",
                "value": 500
              }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Kafka Max Lag",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(kafka_consumer_records_lag_max)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 200
              },
              {
                "color": "red",
                "value": 1000
              }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Stale Feed Ratio",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(business_stale_updates_total[5m])) / clamp_min(sum(rate(business_price_updates_published_total[5m])), 1)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.05
              },
              {
                "color": "red",
                "value": 0.15
              }
            ]
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Incident Signals Timeline",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(business_updates_failed_total[1m]))",
          "legendFormat": "update_failures/s"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum(rate(business_tick_to_screen_latency_ms_bucket[5m])) by (le))",
          "legendFormat": "tick->screen p95 ms"
        },
        {
          "refId": "C",
          "expr": "max(kafka_consumer_records_lag_max)",
          "legendFormat": "kafka lag max"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Flow Stage Event Rates (from logs)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (stage) (rate({compose_service=\"$service\"} | json | message =~ \"FLOW stage=.*\" | regexp \".*FLOW stage=(?P<stage>[^ ]+).*\" [1m]))",
          "legendFormat": "{{stage}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        }
      }
    },
    {
      "type": "logs",
      "title": "Trace Drilldown Logs (by traceId)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{compose_service=\"$service\"} | json | traceId=~\"$trace\""
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "type": "logs",
      "title": "Correlation Drilldown Logs (by correlationId)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{compose_service=\"$service\"} | json | correlationId=~\"$corr\""
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "type": "logs",
      "title": "Recent Errors/Warnings",
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{compose_service=\"$service\"} | json | level =~ \"(ERROR|WARN)\""
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ],
  "links": [
    {
      "title": "Tempo Explore",
      "url": "/explore?orgId=1&left=%5B\"now-1h\",\"now\",\"Tempo\",%7B%7D%5D",
      "targetBlank": false
    },
    {
      "title": "Loki Explore",
      "url": "/explore?orgId=1&left=%5B\"now-1h\",\"now\",\"Loki\",%7B%22expr%22:%22%7Bcompose_service%3D%5C%22app%5C%22%7D%20%7C%20json%22%7D%5D",
      "targetBlank": false
    },
    {
      "title": "Kafka UI",
      "url": "http://localhost:5777",
      "targetBlank": true
    }
  ]
}